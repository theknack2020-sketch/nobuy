default_platform(:ios)

platform :ios do

  def api_key
    app_store_connect_api_key(
      key_id: "4JLWR7B5T4",
      issuer_id: "0d7cd2d5-68c7-4214-854f-26b663d40beb",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_4JLWR7B5T4.p8")
    )
  end

  desc "Create app on App Store Connect"
  lane :create_app do
    create_app_online(
      app_identifier: "com.ufukozdemir.nobuy",
      app_name: "NoBuy",
      language: "English",
      sku: "com.ufukozdemir.nobuy",
      team_id: "99H9NJ6Z6J",
      itc_team_id: ENV["ITC_TEAM_ID"]
    )
  end

  desc "Upload metadata to App Store Connect"
  lane :upload_metadata do
    deliver(
      api_key: api_key,
      app_identifier: "com.ufukozdemir.nobuy",
      skip_binary_upload: true,
      skip_app_version_update: true,
      skip_screenshots: true,
      edit_live: false,
      force: true,
      precheck_include_in_app_purchases: false,
      app_review_information: {},
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    build_app(
      scheme: "NoBuy",
      export_method: "app-store",
      clean: true,
      xcargs: "-allowProvisioningUpdates"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Archive only (no upload)"
  lane :archive do
    build_app(
      scheme: "NoBuy",
      export_method: "app-store",
      clean: true
    )
  end

  desc "Full release: build + metadata + submit"
  lane :release do
    build_app(
      scheme: "NoBuy",
      export_method: "app-store",
      clean: true
    )

    upload_to_app_store(
      api_key: api_key,
      skip_metadata: false,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
  end

end
